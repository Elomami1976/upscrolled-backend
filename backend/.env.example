# UpScrolled Video Downloader - Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Origins (comma-separated)
# Add your production domain here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://upscrolleddownloader.com

# Timeouts (in seconds)
HTTP_TIMEOUT=30
FFMPEG_TIMEOUT=120

# Debug mode (set to false in production)
DEBUG=true
